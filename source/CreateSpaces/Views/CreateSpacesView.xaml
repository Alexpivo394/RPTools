<ui:FluentWindow
    x:Class="CreateSpaces.Views.CreateSpacesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Title="ModelTransplanter"
    WindowStartupLocation="CenterScreen"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    Height="500"
    Width="800"
    MinHeight="400"
    MinWidth="800"
    ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="CreateCover" Icon="AddCircle24" />
        
        <!-- Content -->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0" Margin="0,0,5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="10" BorderThickness="2" BorderBrush="{DynamicResource SystemAccentColorBrush}" CornerRadius="5">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MinHeight="150">
                        <ui:ListView
                            ItemsSource="{Binding LinkedModels, Mode=TwoWay}"
                            SelectedItem="{Binding SelectedLink, Mode=TwoWay}"
                            HorizontalContentAlignment="Stretch"
                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ui:ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0">
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="0"/>
                                    </Grid>
                                </DataTemplate>
                            </ui:ListView.ItemTemplate>
                        </ui:ListView>
                    </ScrollViewer>
                </Border>
                <TextBlock Grid.Row="0" Text="Выберите связанный файл"
                           Background="{DynamicResource WindowBackground}" 
                           Foreground="{DynamicResource WindowForeground}"
                           Padding="5,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Margin="20,-10,0,0"/>
                <ui:ToggleSwitch
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    IsChecked="{Binding CreateSpaces, Mode=TwoWay}"
                    OffContent="Перенести только значения параметров"
                    OnContent="Создать пространства"/>
            </Grid>
            <Grid Grid.Column="1" Margin="5,0,0,0">
                <Border Padding="10" BorderThickness="2" BorderBrush="{DynamicResource SystemAccentColorBrush}" CornerRadius="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <Grid Margin="10,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="Параметр пространства" VerticalAlignment="Center" Margin="0"/>
                            
                            <TextBlock Grid.Column="1" Text="Параметр помещения" VerticalAlignment="Center" Margin="0"/>
                            
                        </Grid>
                        
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MinHeight="150">
                        <ui:ListView
                            ItemsSource="{Binding Models}"
                            HorizontalContentAlignment="Stretch"
                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ui:ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Text="{Binding SpaceParameter.Name}" VerticalAlignment="Center" Margin="0"/>
                                        <ComboBox
                                            Grid.Column="1" ItemsSource="{Binding RoomParameters}" 
                                            DisplayMemberPath="Name"
                                            SelectedItem="{Binding SelectedRoomParameter, Mode=TwoWay}"
                                            Height="35"
                                            Margin="10,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ui:ListView.ItemTemplate>
                        </ui:ListView>
                    </ScrollViewer>
                    </Grid>
                </Border>
                <TextBlock Text="Сопоставление параметров"
                           Background="{DynamicResource WindowBackground}" 
                           Foreground="{DynamicResource WindowForeground}"
                           Padding="5,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Margin="20,-10,0,0"/>
            </Grid>
        </Grid>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,0,0,10">
                <TextBlock Text="Тема:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ui:ToggleSwitch
                    IsChecked="{Binding DataContext.DarkTheme, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}, Mode=TwoWay}"
                    OffContent="Светлая"
                    OnContent="Темная"/>
                
                <ui:Button Content="Экспорт"
                           Icon="{ui:SymbolIcon Symbol=ArrowExportLtr24}"
                           Command="{Binding ExportCommand}"
                           Appearance="Secondary"
                           Margin="20,0,0,0" />
                
                <ui:Button Content="Импорт"
                           Icon="{ui:SymbolIcon Symbol=ArrowImport24}"
                           Command="{Binding ImportCommand}"
                           Appearance="Secondary"
                           Margin="10,0,0,0" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,10">
                <ui:Button Content="Запуск"
                           Icon="{ui:SymbolIcon Rocket24}"
                           Command="{Binding StartCommand}"
                           Appearance="Primary"
                           Margin="10,0,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>